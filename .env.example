# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram to get the token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Add the bot to your group, send a message, then call:
# https://api.telegram.org/bot<TOKEN>/getUpdates  — look for "chat":{"id":...}
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Schedule ─────────────────────────────────────────────────────────────────
# Cron expression (runs in Asia/Jerusalem timezone)
# Default: 09:00 every day
CRON_SCHEDULE=0 9 * * *

# ── Tuning ───────────────────────────────────────────────────────────────────
# Max jobs shown per category (management / senior / mid+junior)
MAX_JOBS_PER_CATEGORY=15

# Set to true to fire the job immediately on startup (useful for testing)
RUN_NOW=false
